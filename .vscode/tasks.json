{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PackY: Clean",
      "detail": "Cleans the build artifacts",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "linux": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-project clean"
      },
      "windows": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-project.exe clean"
      },
      "args": [
        "pyproject.toml"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Build",
      "detail": "Compiles resources, UI files, and QML files if existing and necessary, after having automatically updated the PyProject file",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "linux": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-project build"
      },
      "windows": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-project.exe build"
      },
      "args": [
        "pyproject.toml"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "dependsOn": [
        "PackY: Update PyProject file"
      ]
    },
    {
      "label": "PackY: Update PyProject file",
      "detail": "Update the 'tool.pyside6-project.files' section in a pyproject.toml file",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/update_pyproject_file.py",
        "--relative-to",
        ".",
        "--include-directory",
        "packy",
        "--include-file",
        "resources/packy.qrc",
        "--include-file",
        "main.py"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Update translation files",
      "detail": "Updates all translation (.ts) files",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "linux": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-lupdate"
      },
      "windows": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-lupdate.exe"
      },
      "args": [
        "-extensions",
        "ui,py,qs,qml,qrc",
        "-sort-messages",
        "-recursive",
        "-locations",
        "relative",
        "-tr-function-alias",
        "QT_TR_NOOP+=PACKY_TR_NOOP",
        ".",
        "-ts",
        "@i18n/translations.txt",
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Add new translation file",
      "detail": "Create and reference a new translation (.ts) file",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "linux": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-lupdate -source-language \"en-US\" -target-language \"${input:isoLocaleCode}\" -ts \"i18n/${input:isoLocaleCode}.ts\" && echo i18n/${input:isoLocaleCode}.ts>>\"i18n/translations.txt\""
      },
      "windows": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-lupdate -source-language \"en-US\" -target-language \"${input:isoLocaleCode}\" -ts \"i18n/${input:isoLocaleCode}.ts\" && echo i18n/${input:isoLocaleCode}.ts>>\"i18n/translations.txt\""
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Compile .ui",
      "detail": "[Deprecated: use 'PackY: Build'] Generate .py files from .ui files",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "${command:python.interpreterPath}",
      "args": [
        "scripts/convert_ui_to_py.py"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Run",
      "detail": "Run the PackY app",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "${command:python.interpreterPath}",
      "args": [
        "main.py"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Test",
      "detail": "Run the unit tests",
      "type": "process",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "command": "pytest -v",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "PackY: Deploy",
      "detail": "Deploys the app",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "linux": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-deploy"
      },
      "windows": {
        "command": "${command:python.interpreterPath}/../Scripts/pyside6-deploy.exe"
      },
      "args": [
        "main.py",
        "--config-file",
        "build/pysidedeploy.spec",
        "--verbose",
        "--dry-run",
        "--keep-deployment-files",
        "--name",
        "PackY",
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "dependsOn": [
        "PackY: Build"
      ]
    },
  ],
  "inputs": [
    {
      "type": "promptString",
      "id": "isoLocaleCode",
      "description": "IOS 639 and 3166 local code, e.g., 'fr-FR', 'en-GB', 'de-DE'.",
    }
  ]
}